# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Analysis engine ----
# Velg motor: 'mock' (default, ingen API-nøkler nødvendig), 'revieve' eller 'openai'
ANALYSIS_PROVIDER=mock

# ---- Revieve (når API-tilgang er klar) ----
REVIEVE_API_KEY=
REVIEVE_PARTNER_ID=

# ---- OpenAI (fase 2 - for åpne produktspørsmål) ----
OPENAI_API_KEY=
