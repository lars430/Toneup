# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Analysis engine ----
# Velg motor: 'mock' (default, ingen API-nøkler nødvendig), 'revieve' eller 'openai'
ANALYSIS_PROVIDER=mock

# ---- Revieve (når API-tilgang er klar) ----
REVIEVE_API_KEY=
REVIEVE_PARTNER_ID=

# ---- OpenAI (hudanalyse vision + fremtidige spørsmål) ----
OPENAI_API_KEY=
# Sett til false for kun heuristikk (ingen bilde til OpenAI)
SKIN_ANALYSIS_USE_OPENAI=true
OPENAI_VISION_MODEL=gpt-4o-mini
